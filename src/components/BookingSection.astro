---
import BookingCalendar from './BookingCalendar.tsx';
---

<section id="agendar" class="py-32 bg-white px-6">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-20">
      <h2 class="text-4xl md:text-5xl font-semibold tracking-tight mb-6">Agendar.</h2>
      <p class="text-xl text-neutral-500 max-w-2xl mx-auto font-light leading-relaxed">
        Elige el servicio y horario. Serás redirigido a Mercado Pago para confirmar tu cita.
      </p>
    </div>

    <div class="max-w-3xl mx-auto">
      <BookingCalendar client:visible />
    </div>
  </div>
</section>
