---
import '../styles/global.css';
const { title, description } = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Eugenio Fuenzalida",
  jobTitle: "Psicólogo",
  description: "Psicólogo especializado en alto rendimiento, psicología deportiva y desarrollo profesional. Ciencia, tecnología y mentalidad de élite.",
  url: Astro.site?.toString(),
  sameAs: [],
};
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description || "Psicólogo Eugenio Fuenzalida — Estrategias de Alto Rendimiento: Ciencia, Tecnología y Mentalidad de Élite."} />
    <meta name="author" content="Eugenio Fuenzalida" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <meta property="og:title" content={title || "Psicólogo Eugenio Fuenzalida"} />
    <meta property="og:description" content={description || "Estrategias de Alto Rendimiento: Ciencia, Tecnología y Mentalidad de Élite."} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:locale" content="es_CL" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title || "Psicólogo Eugenio Fuenzalida"} />
    <meta name="twitter:description" content={description || "Estrategias de Alto Rendimiento: Ciencia, Tecnología y Mentalidad de Élite."} />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <title>{title || "Psicólogo Eugenio Fuenzalida"}</title>
  </head>
  <body class="bg-white text-gray-800 antialiased">
    <slot />
  </body>
</html>
