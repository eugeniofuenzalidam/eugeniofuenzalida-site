---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Eugenio Fuenzalida | Neon Elite">
  <div class="min-h-screen bg-slate-950 text-white selection:bg-cyan-500 selection:text-white font-sans overflow-x-hidden relative">
    
    <!-- Background effects -->
    <div class="absolute inset-0 z-0 overflow-hidden pointer-events-none">
      <div class="absolute top-[-10%] left-[-10%] w-96 h-96 bg-cyan-600/30 blur-[120px] rounded-full mix-blend-screen"></div>
      <div class="absolute bottom-[20%] right-[-10%] w-[30rem] h-[30rem] bg-indigo-600/20 blur-[150px] rounded-full mix-blend-screen"></div>
      <div class="absolute top-[40%] left-[20%] w-64 h-64 bg-fuchsia-600/20 blur-[100px] rounded-full mix-blend-screen"></div>
    </div>

    <!-- Navbar -->
    <nav class="relative z-50 border-b border-white/10 backdrop-blur-md bg-slate-950/50 sticky top-0">
      <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
        <div class="text-xl font-bold tracking-tighter flex items-center gap-2">
          <span class="w-8 h-8 rounded-lg bg-gradient-to-br from-cyan-400 to-indigo-500 flex items-center justify-center text-slate-950">EF</span>
          <span class="bg-clip-text text-transparent bg-gradient-to-r from-white to-white/70">Eugenio Fuenzalida</span>
        </div>
        <div class="hidden md:flex gap-8 text-sm font-medium text-white/70">
          <a href="#" class="hover:text-cyan-400 transition-colors">Método</a>
          <a href="#" class="hover:text-cyan-400 transition-colors">Servicios</a>
          <a href="#" class="hover:text-cyan-400 transition-colors">Testimonios</a>
        </div>
        <a href="#agendar" class="hidden md:inline-flex items-center justify-center px-6 py-2.5 text-sm font-medium rounded-full bg-white text-slate-950 hover:bg-cyan-50 hover:scale-105 transition-all shadow-[0_0_20px_rgba(34,211,238,0.2)]">
          Iniciar Proceso
        </a>
      </div>
    </nav>

    <!-- Hero -->
    <section class="relative z-10 pt-32 pb-20 px-6">
      <div class="max-w-7xl mx-auto grid lg:grid-cols-2 gap-16 items-center">
        <div>
          <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/5 border border-white/10 mb-8 backdrop-blur-sm">
            <span class="w-2 h-2 rounded-full bg-cyan-400 animate-pulse"></span>
            <span class="text-xs font-semibold tracking-wider text-cyan-400 uppercase">Psicología de Alto Rendimiento</span>
          </div>
          <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight mb-8 leading-[1.1]">
            Hackea tu mente.<br/>
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 via-indigo-400 to-fuchsia-400">Desbloquea tu potencial.</span>
          </h1>
          <p class="text-lg md:text-xl text-white/60 mb-10 max-w-xl leading-relaxed">
            Ciencia, tecnología y mentalidad de élite aplicada al deporte y desarrollo profesional. Eleva tus estándares a niveles que creías imposibles.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a href="#agendar" class="inline-flex items-center justify-center px-8 py-4 text-base font-bold rounded-full bg-gradient-to-r from-cyan-500 to-indigo-600 text-white hover:shadow-[0_0_30px_rgba(34,211,238,0.4)] hover:scale-105 transition-all">
              Agendar Evaluación
            </a>
            <a href="#metodo" class="inline-flex items-center justify-center px-8 py-4 text-base font-bold rounded-full bg-white/5 border border-white/10 text-white hover:bg-white/10 transition-all backdrop-blur-sm">
              Conocer el Método
            </a>
          </div>
        </div>
        <div class="relative">
          <div class="aspect-square rounded-3xl overflow-hidden border border-white/10 bg-gradient-to-br from-white/5 to-white/0 p-2 backdrop-blur-sm relative shadow-2xl">
            <!-- Simulated 3D Element or Image placeholder -->
            <div class="absolute inset-0 bg-[url('https://images.unsplash.com/photo-1551854838-212c50b4c465?q=80&w=2000&auto=format&fit=crop')] bg-cover bg-center opacity-50 mix-blend-luminosity grayscale"></div>
            <div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-transparent to-transparent"></div>
            
            <div class="absolute bottom-8 left-8 right-8 p-6 rounded-2xl bg-white/10 backdrop-blur-md border border-white/20">
              <div class="flex items-center gap-4 mb-4">
                <div class="w-12 h-12 rounded-full bg-cyan-500/20 flex items-center justify-center text-cyan-400">
                  <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
                </div>
                <div>
                  <h3 class="font-bold text-white">Rendimiento Cognitivo</h3>
                  <p class="text-sm text-cyan-400">+42% mejora medida</p>
                </div>
              </div>
              <div class="h-2 w-full bg-white/10 rounded-full overflow-hidden">
                <div class="h-full bg-gradient-to-r from-cyan-400 to-indigo-500 w-[85%]"></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Enfoque -->
    <section id="metodo" class="relative z-10 py-24 border-t border-white/5 bg-slate-950/50">
      <div class="max-w-7xl mx-auto px-6">
        <div class="text-center mb-16">
          <h2 class="text-3xl md:text-5xl font-bold mb-6">El Framework de Élite</h2>
          <p class="text-white/60 max-w-2xl mx-auto">No se trata de motivación, se trata de sistemas. Utilizando biofeedback, neurociencia y psicología deportiva para construir mentes inquebrantables.</p>
        </div>
        
        <div class="grid md:grid-cols-3 gap-8">
          {[
            { title: "Neuro-Optimización", desc: "Mapeo y entrenamiento de ondas cerebrales para entrar en estado de flujo a voluntad.", icon: "M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z" },
            { title: "Gestión del Estrés", desc: "Protocolos avanzados de regulación del sistema nervioso autónomo en situaciones de alta presión.", icon: "M13 10V3L4 14h7v7l9-11h-7z" },
            { title: "Arquitectura de Hábitos", desc: "Ingeniería del comportamiento para automatizar el éxito y eliminar la fatiga de decisión.", icon: "M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" }
          ].map(item => (
            <div class="p-8 rounded-3xl bg-white/5 border border-white/10 hover:bg-white/10 transition-colors group">
              <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-cyan-500/20 to-indigo-500/20 border border-cyan-500/30 flex items-center justify-center text-cyan-400 mb-6 group-hover:scale-110 transition-transform">
                <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={item.icon} /></svg>
              </div>
              <h3 class="text-xl font-bold mb-4">{item.title}</h3>
              <p class="text-white/60 leading-relaxed">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  </div>
</Layout>
