---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import EnfoqueSection from '../components/EnfoqueSection.astro';
import ServiceSection from '../components/ServiceSection.astro';
import Newsletter from '../components/Newsletter.astro';
import ImageGrid from '../components/ImageGrid.astro';
import Footer from '../components/Footer.astro';
import BookingSection from '../components/BookingSection.astro';
import ReviewsCarousel from '../components/ReviewsCarousel.astro';
---

<Layout title="Eugenio Fuenzalida | Alto Rendimiento">
  <div class="min-h-screen bg-[#FDFDFD] text-neutral-900 font-sans selection:bg-black selection:text-white overflow-x-hidden">
    <Navbar />
    <main>
      <Hero />
      <ReviewsCarousel />
      <About />
      <ServiceSection />
      <EnfoqueSection />
      <BookingSection />

      <Newsletter />
      <ImageGrid />
    </main>
    <Footer />
  </div>

  <script>
    document.querySelectorAll('[data-accordion-trigger]').forEach((trigger) => {
      trigger.addEventListener('click', () => {
        const parent = trigger.closest('.group\\/accordion');
        if (!parent) return;

        const content = parent.querySelector('[data-accordion-content]');
        const icon = trigger.querySelector('.accordion-icon');

        if (content?.classList.contains('hidden')) {
          content.classList.remove('hidden');
          content.style.maxHeight = '0';
          content.style.overflow = 'hidden';
          content.style.transition = 'max-height 0.3s ease-out';
          requestAnimationFrame(() => {
            content.style.maxHeight = content.scrollHeight + 'px';
          });
          icon?.classList.add('rotate-180');
        } else {
          content.style.maxHeight = '0';
          icon?.classList.remove('rotate-180');
          setTimeout(() => {
            content?.classList.add('hidden');
            content.style.maxHeight = '';
            content.style.overflow = '';
            content.style.transition = '';
          }, 300);
        }
      });
    });

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('opacity-100', 'translate-y-0');
            entry.target.classList.remove('opacity-0', 'translate-y-8');
          }
        });
      },
      { threshold: 0.1 }
    );

    document.querySelectorAll('section').forEach((section) => {
      section.classList.add('transition-all', 'duration-700', 'opacity-0', 'translate-y-8');
      observer.observe(section);
    });
  </script>
</Layout>
